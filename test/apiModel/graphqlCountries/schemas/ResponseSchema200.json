{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "data"
  ],
  "properties": {
    "data": {
      "type": "object",
      "required": [
        "country"
      ],
      "properties": {
        "country": {
          "type": "object",
          "required": [
            "code",
            "name",
            "capital",
            "currency",
            "continent"
          ],
          "properties": {
            "code": {
              "type": "string"
            },
            "name": {
              "type": "string"
            },
            "capital": {
              "type": "string"
            },
            "currency": {
              "type": "string"
            },
            "continent": {
              "type": "object",
              "required": [
                "name"
              ],
              "properties": {
                "name": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    }
  }
}
